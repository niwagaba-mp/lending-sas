PORT=5000
NODE_ENV=development

# PostgreSQL — CHANGE THESE IN PRODUCTION
DATABASE_URL=postgresql://postgres:CHANGE_ME@localhost:5432/smos_db

# JWT — MUST be replaced with cryptographically random secrets (64+ chars)
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_RANDOM_SECRET
JWT_EXPIRES_IN=8h
JWT_REFRESH_EXPIRES_IN=7d

# CORS - Comma-separated list of allowed origins (e.g. https://domain.com,https://api.domain.com,capacitor://localhost)
ALLOWED_ORIGINS=http://localhost:5173

# Logging
LOG_LEVEL=info
